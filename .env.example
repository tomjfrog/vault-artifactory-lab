# Copy to .env and fill in your values — NEVER commit .env
#
# VAULT_TOKEN=root is for local Vault dev mode only (vault server -dev).
# Do not use root or dev tokens in production.

# JFrog Platform (cloud sandbox)
JFROG_URL=https://YOUR-TENANT.jfrog.io
ARTIFACTORY_USERNAME=vault-admin
# ARTIFACTORY_PASSWORD=        # bootstrap only; prefer access token
JFROG_ACCESS_TOKEN=            # admin-scoped token (applied-permissions/admin)
JFROG_SERVER_ID=YOUR-SERVER-ID # jf config server id (e.g. from jf config add)

# Vault (local dev server)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root

# Plugin repo (sibling checkout)
PLUGIN_REPO=../vault-plugin-secrets-artifactory
PLUGIN_VAULT_PATH=artifactory

# --- CMDB app ASK123 (JFrog project ask123) ---
ASK123_ID=ASK123
ASK123_PROJECT=ask123
ASK123_GROUP=AZU_ARTIFACTORY_ASK123
ASK123_DEV_REPO=ask123-docker-dev-local
ASK123_PROD_REPO=ask123-docker-prod-local
ASK123_PERMISSION=ask123-docker-prod-pull
ASK123_DOCKER_IMAGE=ask-123-demo
ASK123_VAULT_ROLE=ask123
ASK123_VAULT_POLICY=ask123-pull
ASK123_NAMESPACE=ask123-ns
ASK123_K8S_AUTH_ROLE=ask123-workload

# --- CMDB app ASK456 (JFrog project ask456) ---
ASK456_ID=ASK456
ASK456_PROJECT=ask456
ASK456_GROUP=AZU_ARTIFACTORY_ASK456
ASK456_DEV_REPO=ask456-docker-dev-local
ASK456_PROD_REPO=ask456-docker-prod-local
ASK456_PERMISSION=ask456-docker-prod-pull
ASK456_DOCKER_IMAGE=ask-456-demo
ASK456_VAULT_ROLE=ask456
ASK456_VAULT_POLICY=ask456-pull
ASK456_NAMESPACE=ask456-ns
ASK456_K8S_AUTH_ROLE=ask456-workload

# Shared lab defaults (ASK123 primary path for Phases 1–3)
DOCKER_TAG=1.0.0
K8S_WORKLOAD_SA=workload-sa
VAULT_K8S_AUTH_PATH=kubernetes

# Phase 3 — External Secrets Operator (ASK123 namespace)
VAULT_URL_FOR_CLUSTER=http://host.docker.internal:8200
ESO_NAMESPACE=external-secrets

# Legacy aliases used by scripts (map to ASK123)
ASK_ID=ASK123
ARTIFACTORY_GROUP=AZU_ARTIFACTORY_ASK123
DEMO_ROLE=ask123
DOCKER_DEV_REPO=ask123-docker-dev-local
DOCKER_PROD_REPO=ask123-docker-prod-local
DOCKER_IMAGE=ask-123-demo
K8S_NAMESPACE=ask123-ns
K8S_AUTH_ROLE=ask123-workload
