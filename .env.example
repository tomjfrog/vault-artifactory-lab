# Copy to .env and fill in your values — NEVER commit .env
#
# VAULT_TOKEN=root is for local Vault dev mode only (vault server -dev).
# Do not use root or dev tokens in production.

# JFrog Platform (cloud sandbox)
JFROG_URL=https://YOUR-TENANT.jfrog.io
ARTIFACTORY_USERNAME=vault-admin
# ARTIFACTORY_PASSWORD=        # bootstrap only; prefer access token
JFROG_ACCESS_TOKEN=            # admin-scoped token (applied-permissions/admin)
JFROG_SERVER_ID=YOUR-SERVER-ID # jf config server id (e.g. from jf config add)

# Vault (local dev server)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root

# Plugin repo (sibling checkout)
PLUGIN_REPO=../vault-plugin-secrets-artifactory
PLUGIN_VAULT_PATH=artifactory

# CMDB application ID (customer convention) — ASK123
ASK_ID=ASK123
ARTIFACTORY_GROUP=AZU_ARTIFACTORY_ASK123
DEMO_ROLE=vaultdemo
DEMO_GROUP=AZU_ARTIFACTORY_ASK123
DEMO_REPO=vaultdemo-docker-prod-local

# Lab Docker image (ASK123)
DOCKER_DEV_REPO=vaultdemo-docker-local
DOCKER_PROD_REPO=vaultdemo-docker-prod-local
DOCKER_IMAGE=lab-demo
DOCKER_TAG=1.0.0

# Phase 2 — Vault Kubernetes auth
K8S_NAMESPACE=vaultdemo-ns
K8S_WORKLOAD_SA=workload-sa
K8S_AUTH_ROLE=vaultdemo-workload
VAULT_K8S_AUTH_PATH=kubernetes
# Advanced (defaults in scripts; see docs/appendix/phase2-kubernetes-auth-notes.md):
# K8S_VAULT_AUTH_SA=vault-auth
# K8S_VAULT_AUTH_NS=kube-system
# K8S_VAULT_AUTH_BINDING=vault-auth-delegator
# K8S_REVIEWER_TOKEN_DURATION=87600h
# K8S_WORKLOAD_TOKEN_DURATION=1h

# Phase 3 — External Secrets Operator
VAULT_URL_FOR_CLUSTER=http://host.docker.internal:8200
ESO_NAMESPACE=external-secrets

# Phase 4 — second CMDB app (multi-app isolation)
ASK456_ID=ASK456
ASK456_GROUP=AZU_ARTIFACTORY_ASK456
ASK456_ROLE=vaultdemo-ask456
ASK456_PROD_REPO=vaultdemo-docker-ask456-prod-local
ASK456_DOCKER_IMAGE=lab-demo-ask456
ASK456_NAMESPACE=vaultdemo-ask456-ns
ASK456_K8S_AUTH_ROLE=vaultdemo-ask456-workload
